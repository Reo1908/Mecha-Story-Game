# Unity .gitignore
# Basierend auf https://github.com/github/gitignore/blob/main/Unity.gitignore

# Unity generierte Ordner (werden beim Öffnen neu erzeugt)
.utmp/
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log

# MemoryCaptures / Recordings können riesig werden
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Blender-Backupdateien
*.blend1
*.blend1.meta

# Autogenerierte Jetbrains-Rider-Plugin-Dateien
/[Aa]ssets/Plugins/Editor/JetBrains*
*.DotSettings.user

# IDE / Editor
.vs/
.vscode/
.idea/
.consulo/
.gradle/
ExportedObj/

# Autogenerierte Solution-/Projektdateien
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity generierte Meta-Dateien
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity Crash-Reports
sysinfo.txt
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics
crashlytics-build.properties

# TestRunner / Playmode-Test-Szenen
/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*

# Addressables
/ServerData
/[Aa]ssets/StreamingAssets/aa*
/[Aa]ssets/AddressableAssetsData/link.xml*
/[Aa]ssets/Addressables_Temp*
/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting autogenerierte Dateien
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# OS-Dateien
.DS_Store
Thumbs.db
